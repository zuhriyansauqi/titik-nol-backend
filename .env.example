# ─── App ──────────────────────────────────────────────────
APP_NAME=titik-nol-backend
APP_ENV=local            # local | staging | production
APP_PORT=8080

# ─── Database (PostgreSQL) ────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=password_rahasia
DB_NAME=titik_nol
DB_SSLMODE=disable       # disable | require | verify-full
DB_TIMEZONE=Asia/Jakarta

# Connection pool
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=100
DB_CONN_MAX_LIFETIME=1h

# ─── Logging ─────────────────────────────────────────────
LOG_LEVEL=info           # debug | info | warn | error
LOG_FORMAT=json          # json (production) | text (development)

# ─── Auth ─────────────────────────────────────────────────
JWT_SECRET=your_secret_key_here
JWT_ISSUER=titik-nol-backend
JWT_EXPIRY_SECONDS=86400              # 24 hours
GOOGLE_CLIENT_ID=your_google_client_id_here

# ─── CORS & Rate Limiting ────────────────────────────────
CORS_ALLOW_ORIGINS=http://localhost:3000
RATE_LIMIT_RPS=10        # Requests per second
RATE_LIMIT_BURST=20      # Burst size

# ─── Redis ────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── Cache ────────────────────────────────────────────────
CACHE_ENABLED=true
CACHE_DEFAULT_TTL=5m
CACHE_CATEGORY_TTL=30m
CACHE_DASHBOARD_TTL=2m
CACHE_USER_TTL=10m
CACHE_ACCOUNT_TTL=5m
