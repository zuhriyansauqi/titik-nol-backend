{
  "enabled": true,
  "name": "Test on Save",
  "description": "Runs the full test suite whenever a Go file is saved.",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/*.go"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "cd \"$(git rev-parse --show-toplevel)\" && go test ./..."
  }
}
